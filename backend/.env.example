DATABASE_URL=postgresql://user:password@host:5432/dbname

APP_ENV=development
APP_NAME=JAWCOM
DEBUG=true

# JAWIS Business OS API credentials
JAWIS_BASE_URL=https://your-jawis-instance.com
JAWIS_API_KEY=your-api-key
JAWIS_WORKSPACE=your-workspace-id

# JAWIS Communication API (Sprint-1 messages/*.send endpoints) — required for
# "whatsapp"/"email" nodes to send anything; without this every send fails
# immediately (no retry). Distinct token from JAWIS_API_KEY above.
JAWIS_API_TOKEN=your-communication-api-token

# Provider selection (dummy | jawis)
JAWIS_LEAD_PROVIDER=dummy
JAWIS_CRM_PROVIDER=dummy

# WhatsApp integration (if using real API)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# Email integration (if using SMTP)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# Gmail reply-sync (POST /api/email-sync/run) — migrated from JAWIS.
# Single shared mailbox, OAuth refresh token minted once outside the app.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_MONITOR_EMAIL=

# Shared secret required in the X-Webhook-Token header on
# POST /api/email-sync/run — same pattern as JAWIS's WEBHOOK_TOKEN.
EMAIL_SYNC_WEBHOOK_TOKEN=

# Admin auth (app/core/jawis_auth_middleware.py). No env-configured
# password — accounts are created via
# `python -m app.scripts.create_admin --email you@company.com --name "You"`.
# In production: ADMIN_SESSION_COOKIE_SECURE=true always; set
# ADMIN_SESSION_COOKIE_SAMESITE=none if the frontend is on a different
# domain than the API (also requires CORS_ORIGINS set to the exact
# frontend origin, not "*").
ADMIN_SESSION_COOKIE_SECURE=true
ADMIN_SESSION_COOKIE_SAMESITE=lax
ADMIN_SESSION_COOKIE_DOMAIN=
ADMIN_OTP_RECIPIENT_EMAIL=sales@nextmovein.com
CORS_ORIGINS=
